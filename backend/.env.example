# ─────────────────────────────────────────────────────────────
# Stock AI Analyzer - 配置模板
# 复制此文件为 .env 并填入真实值
# 注意: .env 文件绝对不要提交到 git
# ─────────────────────────────────────────────────────────────

# ─── tushare ─────────────────────────────────────────────────
# 从 https://tushare.pro 注册获取
TUSHARE_TOKEN=your_tushare_token_here


# ─── Google Gemini ───────────────────────────────────────────
# 从 https://aistudio.google.com/ 免费申请
GEMINI_API_KEY=your_gemini_api_key_here

# 选股扫描用（快速、低成本）
GEMINI_MODEL_FAST=gemini-3.1-flash-lite

# 深度分析用（手动触发）
GEMINI_MODEL_PRO=gemini-3.1-pro

# ─── 企业微信通知 ─────────────────────────────────────────────
# 企业微信群 → 添加群机器人 → 复制 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# ─── 邮件备份通知（可选）────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# ─── 服务配置 ─────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ─── 数据刷新间隔（秒，建议 120-300）────────────────────────
POLL_INTERVAL=180

# ─── 数据库路径（相对于 backend/ 目录）──────────────────────
DB_PATH=db/stock_analyzer.db
